# Copy to .env and adjust as needed.

# App
APP_NAME=Studying App
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:4200","http://127.0.0.1:4200"]

# Database (SQLite by default)
DATABASE_URL=sqlite:///./studying_app.db

# Security
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
ALGORITHM=HS256

# First admin user (created by seed script if missing)
FIRST_ADMIN_EMAIL=admin@codewithtlp.com
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=admin@123

# Code runner (Docker)
DOCKER_ENABLED=true
RUNNER_DEFAULT_TIMEOUT_SEC=5
RUNNER_DEFAULT_MEMORY_MB=256
RUNNER_DEFAULT_CPU=0.5
RUNNER_IMAGE_PYTHON=studying-runner-python:latest
RUNNER_IMAGE_NODE=studying-runner-node:latest
RUNNER_IMAGE_JAVA=studying-runner-java:latest
RUNNER_IMAGE_CSHARP=studying-runner-csharp:latest
